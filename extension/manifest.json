{
  "manifest_version": 3,
  "name": "Browser Picker bridge",
  "version": "1.0",
  "description": "Routes links opened from Chromium web-app (--app=) windows through browser-picker instead of a new Chromium window.",
  "key": "",
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["webNavigation", "tabs", "nativeMessaging"],
  "host_permissions": ["<all_urls>"]
}
